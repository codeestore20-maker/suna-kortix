{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "backend",
      "dockerfilePath": "backend/Dockerfile",
      "build": {
        "builder": "DOCKERFILE"
      },
      "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    },
    {
      "name": "frontend",
      "dockerfilePath": "apps/frontend/Dockerfile",
      "build": {
        "builder": "DOCKERFILE"
      },
      "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      }
    }
  ]
}
